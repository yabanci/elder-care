POSTGRES_USER=eldercare
POSTGRES_PASSWORD=eldercare_dev
POSTGRES_DB=eldercare
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

DATABASE_URL=postgres://eldercare:eldercare_dev@localhost:5433/eldercare?sslmode=disable

JWT_SECRET=change_me_in_prod_please_use_long_random_string
JWT_TTL_HOURS=168

SERVER_ADDR=:8090
# Mobile clients use Bearer tokens, no CORS needed. The "*" wildcard is
# fine for local dev; restrict to specific origins in production if you
# also serve any web client (admin console, debug page, etc.).
CORS_ORIGIN=*

# SECURE_COOKIES forces the auth cookie's Secure flag. Default true.
# Set to "false" only for local dev on plain HTTP.
SECURE_COOKIES=false

# Web Push (VAPID). Generate keys with `npx web-push generate-vapid-keys`
# and paste below. Empty values disable push entirely.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@eldercare.local
